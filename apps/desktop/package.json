    "better-sqlite3": "^11.0.0",
    "chokidar": "^4.0.0",
    "electron-log": "^5.0.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.0.0",
    "exifreader": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^34.0.0",
    "electron-builder": "^25.0.0",
