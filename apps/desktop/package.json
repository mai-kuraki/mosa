{
  "name": "mosa-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint electron/ src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
